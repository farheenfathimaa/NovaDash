      <aliases enabled='yes' />
      <column caption='Total Revenue' datatype='real' name='[Calculation_0588291360608259]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Units_Sold] * [Unit_Price] * (1 - [Discount_Pct])' />
      </column>
      <column caption='Total Cost' datatype='real' name='[Calculation_0588291361300484]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Units_Sold] * [Unit_Price] * 0.65' />
      </column>
      <column caption='Total Profit' datatype='real' name='[Calculation_0588291361427461]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_0588291360608259] - [Calculation_0588291361300484]' />
      </column>
      <column caption='Profit Margin' datatype='real' name='[Calculation_0588291373129736]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Calculation_0588291361427461]) / SUM([Calculation_0588291360608259])' />
      </column>
